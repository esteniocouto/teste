-- 6 - realize uma consulta que traga o nome do dono, o nome do animal, a raça do animal, o valor da consulta, ordenado decrescentemente pelo nome do animal:
select dono.nome, animal.nomeanimal, raca.nomeraca, atende.vlratendimento
from dono, animal, raca, atende
WHERE  dono.iddono = animal.idanimal and animal.idraca = raca.idraca and atende.idanimal = animal.idanimal
GROUP BY animal.nomeanimal; 

-- 7 - realize uma consulta que retorne a quantidade de animais que cada dono possui:
select dono.nome,  count(idanimal)
from dono, possui
where dono.iddono = possui.idanimal
group by dono.nome;


-- 8 - realize uma consulta que retorne a quantidade de animais atendidos por cada veterinário;
select atende.idveterinario, veterinario.nomeveterinario, count(idanimal) as quant_animais_atendidos
from atende, veterinario
where atende.idanimal = atende.idanimal and atende.idveterinario = veterinario.idveterinario
group by veterinario.nomeveterinario;

-- 9 - construa uma View que retorne a quantidade de animais atendidos por dia:
select atende.dtatendimento, count(dtatendimento) as qtde
from atende
where atende.dtatendimento = atende.dtatendimento
group by atende.dtatendimento;


