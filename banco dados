create database PetShop;
use PetShop;

create table dono(
    iddono integer primary key auto_increment,
    nome varchar(50),
    cpfdono bigint,
    fonedono bigint 
    );
    

create table veterinario (
idveterinario integer primary key auto_increment, 
nomeveterinario varchar(50),
cpfveterinario bigint,
registroveterinario bigint,
foneveterinario bigint 
   );
    
  create table raca( 
idraca integer primary key auto_increment, 
nomeraca varchar(25)
);

  create table animal( 
idanimal integer primary key auto_increment,
nomeanimal varchar (30),
idadeanimal int (2),
sexo varchar (10),
idraca integer,
  constraint pk_anirac foreign key (idraca)
     references raca (idraca)
 );

create table atende (
dtatendimento date,
vlratendimento decimal(7,2),
idveterinario integer,
idanimal integer,
constraint pk_atevet foreign key (idveterinario)
     references veterinario (idveterinario),
constraint pk_ateani foreign key (idanimal)
     references animal (idanimal)
);

create table possui (
iddono integer,
idanimal integer,

constraint pk_posdon foreign key (iddono)
    references dono (iddono),
constraint pk_posani foreign key (idanimal)
     references animal (idanimal)
);

